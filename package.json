{
  "name": "agent-runbook-skill",
  "version": "0.1.0",
  "description": "Turn Markdown runbooks into bounded dry-run agent action plans.",
  "type": "module",
  "bin": {
    "agent-runbook": "./bin/cli.js"
  },
  "scripts": {
    "build": "npm run check",
    "check": "node --check src/index.js && node --check bin/cli.js",
    "lint": "node --check src/index.js && node --check bin/cli.js",
    "test": "node --test",
    "smoke": "node bin/cli.js fixtures/release-runbook.md",
    "package:smoke": "node scripts/package-smoke.js",
    "release:check": "bash scripts/validate.sh"
  },
  "keywords": [
    "agent-skill",
    "cli",
    "dry-run"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/agent-runbook-skill.git"
  },
  "files": [
    "bin",
    "src",
    "scripts/package-smoke.js",
    "docs",
    "fixtures",
    "SKILL.md",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "CHANGELOG.md"
  ],
  "bugs": {
    "url": "https://github.com/rogerchappel/agent-runbook-skill/issues"
  },
  "homepage": "https://github.com/rogerchappel/agent-runbook-skill#readme"
}
