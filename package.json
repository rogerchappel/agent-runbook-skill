{
  "name": "agent-runbook-skill",
  "version": "0.1.0",
  "description": "Turn Markdown runbooks into bounded dry-run agent action plans.",
  "type": "module",
  "bin": {
    "agent-runbook": "./bin/cli.js"
  },
  "scripts": {
    "test": "node --test",
    "check": "node --check src/index.js && node --check bin/cli.js",
    "build": "npm run check",
    "smoke": "node bin/cli.js fixtures/release-runbook.md",
    "package:smoke": "node scripts/package-smoke.js",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke"
  },
  "files": [
    "bin",
    "docs",
    "fixtures",
    "src",
    "SKILL.md",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "CHANGELOG.md"
  ],
  "keywords": [
    "agent-skill",
    "cli",
    "dry-run"
  ],
  "license": "MIT"
}
